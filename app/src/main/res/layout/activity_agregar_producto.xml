<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/colorBackground"
    tools:context=".Agregar_Producto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/color_fondo"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnRetroceso"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ic_Retroceder"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/retroceso"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/colorOnSecondary" />

            <ImageView
                android:id="@+id/Logo_app"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/logo_App"
                android:src="@drawable/logo_app"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTituloEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/Añadir_Inventario"
                android:textColor="@color/colorOnSecondary"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtitulo_Agregar_Producto"
                android:textColor="@color/gris"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTituloEditar" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/headerDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:alpha="0.4"
            android:background="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header" />


        <TextView
            android:id="@+id/labelPaso2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:paddingStart="20dp"
            android:text="@string/label_Paso1_Producto_Añadir"
            android:textColor="@color/colorOnSecondary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerDivider" />

        <LinearLayout
            android:id="@+id/cvFormulario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelPaso2"
            >

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombreProducto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/NombreProducto"
                app:boxStrokeColor="@color/colorPrimary"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:boxStrokeWidthFocused="0dp"
                app:counterMaxLength="@integer/NombreProducto">


                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZñÑ "
                    app:counterMaxLength="@integer/NombreProducto"
                    android:inputType="textMultiLine"
                    android:maxLength="50"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescripcionProducto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/Presentación"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:boxStrokeWidthFocused="0dp"
                app:counterMaxLength="@integer/Presentacion"

                >
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescripcionProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="textMultiLine"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZñÑ1234567890 "
                    android:textSize="15sp"
                    android:maxLength="30"
                    app:counterMaxLength="@integer/Presentacion"
                    />
            </com.google.android.material.textfield.TextInputLayout>


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCatategoriaProducto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/CategoriaProducto"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:boxStrokeColor="@color/colorPrimary"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconTint="@color/colorOnSecondary">


                <AutoCompleteTextView
                    android:id="@+id/etCatagoriaProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:inputType="none"
                    android:textSize="15sp"
                    android:textColor="@color/colorOnSecondary"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPrecioProductoCompra"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:hint="@string/precioCompra"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/PrecioProducto"
                app:boxStrokeWidthFocused="0dp"
                app:prefixText="$ "
                app:prefixTextColor="@color/colorOnSecondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrecioProductoCompra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="numberDecimal"
                    android:textSize="15sp"
                    android:maxLength="11"
                    app:counterMaxLength="11"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPrecioProducto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/precioVenta"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/PrecioProducto"
                app:boxStrokeWidthFocused="0dp"
                app:prefixText="$ "
                app:prefixTextColor="@color/colorOnSecondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrecioProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="number"
                    android:textSize="15sp"
                    android:maxLength="11"
                    app:counterMaxLength="11"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCantidadProducto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/Cantidad"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:boxStrokeWidthFocused="0dp"
                app:counterMaxLength="@integer/CantidadProducto"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCantidadProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="number"
                    android:textSize="15sp"
                    android:maxLength="11"
                    app:counterMaxLength="@integer/CantidadProducto"
                    />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarProducto"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:text="@string/GUARDARPRODUCTONUEVO"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@color/btn_registrarse"
            app:cornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvFormulario"
            tools:enabled="true" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>