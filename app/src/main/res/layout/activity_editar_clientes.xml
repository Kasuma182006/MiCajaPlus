<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/colorBackground"
    tools:context=".editar_clientes">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/color_fondo"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnRetroceso"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ic_Retroceder"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/retroceso"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/colorOnSecondary" />

            <ImageView
                android:id="@+id/Logo_app"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/logo_App"
                android:src="@drawable/logo_app"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTituloEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/titulo_EditarCliente"
                android:textColor="@color/colorOnSecondary"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtitulo_EditarCliente"
                android:textColor="@color/gris"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTituloEditar" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/headerDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:alpha="0.4"
            android:background="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header" />

        <TextView
            android:id="@+id/labelPaso1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:paddingStart="20dp"
            android:text="@string/label_Paso1"
            android:textColor="@color/colorOnSecondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerDivider" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvBuscador"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelPaso1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textBuscarCliente"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/colorOnSecondary"
                    app:hintEnabled="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnBuscarCliente"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBuscarCliente"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="@string/hint_BuscarCliente"
                        android:textColorHint="@color/gris"
                        android:imeOptions="actionSearch"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuscarCliente"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:background="@android:color/transparent"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_search"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/ic_principal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/labelPaso2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:paddingStart="20dp"
            android:text="@string/label_Paso2"
            android:textColor="@color/colorOnSecondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvBuscador" />

        <LinearLayout
            android:id="@+id/cvFormulario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:alpha="0.5"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelPaso2"
            android:enabled="false"
            tools:alpha="1.0">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombreCliente"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_NombreCliente"
                app:boxStrokeColor="@color/colorPrimary"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/NombreCliente"

                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="textPersonName"
                    android:enabled="false"
                    android:textSize="15sp"
                    android:maxLength="40"
                    app:counterMaxLength="@integer/NombreCliente"
                    />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCedulaCliente"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:hint="@string/hint_CedulaCliente"
                app:boxStrokeColor="@color/colorPrimary"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/Cedula"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCedulaCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="phone"
                    android:enabled="false"
                    android:textSize="15sp"
                    android:maxLength="10"
                    app:counterMaxLength="@integer/Cedula"
                    />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTelefonoCliente"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:hint="@string/hint_TelefonoCliente"
                app:boxStrokeColor="@color/colorPrimary"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/Telefono"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelefonoCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="phone"
                    android:enabled="false"
                    android:textSize="15sp"
                    android:maxLength="10"
                    app:counterMaxLength="@integer/Telefono"
                    />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilValorCredito"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:hint="@string/hint_ValorCredito"
                app:boxStrokeColor="@color/colorPrimary"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="@color/colorOnSecondary"
                app:prefixText="$ "
                app:prefixTextColor="@color/colorOnSecondary"
                app:endIconMode="clear_text"
                app:endIconTint="@color/colorOnSecondary"
                app:counterEnabled="true"
                app:counterMaxLength="@integer/valorCredito"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etValorCredito"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_chat_tendero"
                    android:inputType="phone"
                    android:enabled="false"
                    android:textSize="15sp"
                    android:maxLength="11"
                    app:counterMaxLength="@integer/valorCredito"
                    />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarCliente"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:text="@string/btn_ActualizarDatos"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@color/btn_registrarse"
            app:cornerRadius="30dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvFormulario"
            app:rippleColor="@color/colorPrimary"
            tools:enabled="true" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>